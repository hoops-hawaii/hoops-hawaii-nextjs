generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id       Int    @id @default(autoincrement())
  username    String @unique
  password String
  role     Role   @default(USER)
  skill Skill @default(mid)
  bio String
  homeCourt Court
}

enum Condition {
  very_good
  good
  mid
  bad
  trash
}

model Court {
  id        Int       @id @default(autoincrement())
  name      String
  capacity  Int
  present   Int
  condition Condition @default(mid)
  news      News[]
}

model News {
  id Int @id @default(autoincrement())
  courtId Int
  news String
  createdAt DateTime @default(now())
  Court Court @relation(fields: [courtId], references: [id])
}

enum Skill {
  goated
  pro
  mid
  beginner
  trash
  fat_chud
}
