generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  pfp         String?
  password    String
  role        Role     @default(USER)
  skill       Skill    @default(mid)
  bio         String?
  homeCourtId Int?
  teamId      Int?
  friends     String[]
  presentAtId Int?
  ownedTeam   Team?    @relation("TeamOwner")
  homeCourt   Court?   @relation(fields: [homeCourtId], references: [id])
  presentAt   Court?   @relation("PresentUsers", fields: [presentAtId], references: [id])
  team        Team?    @relation("TeamMembers", fields: [teamId], references: [id])
  savedCourts Court[]  @relation("SavedCourts")
}

model Team {
  id          Int    @id @default(autoincrement())
  ownerId     Int    @unique
  description String
  name        String
  owner       User   @relation("TeamOwner", fields: [ownerId], references: [id])
  users       User[] @relation("TeamMembers")
}

model Court {
  id           Int       @id @default(autoincrement())
  name         String
  address      String
  environment  String
  capacity     Int
  present      Int
  condition    Condition @default(mid)
  imageURL     String?
  news         News[]
  users        User[]
  presentUsers User[]    @relation("PresentUsers")
  savedByUsers User[]    @relation("SavedCourts")
}

model News {
  id        Int      @id @default(autoincrement())
  courtId   Int
  news      String
  createdAt DateTime @default(now())
  court     Court    @relation(fields: [courtId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum Condition {
  very_good
  good
  mid
  bad
  trash
}

enum Skill {
  goated
  pro
  mid
  beginner
  trash
}
