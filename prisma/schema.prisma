// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id       Int    @id @default(autoincrement())
  username    String @unique
  pfp      String?
  password String
  role     Role   @default(USER)
  skill Skill @default(mid)
  bio String?
  homeCourt Court? @relation(fields: [homeCourtId], references: [id])
  homeCourtId Int?
  team        Team?  @relation("TeamMembers", fields: [teamId], references: [id])
  teamId      Int?
  ownedTeam   Team?  @relation("TeamOwner")
}

model Team {
  id          Int    @id @default(autoincrement())
  owner       User   @relation("TeamOwner", fields: [ownerId], references: [id])
  ownerId     Int    @unique
  users       User[] @relation("TeamMembers")
  description String
  friends   String[]
}

enum Condition {
  very_good
  good
  mid
  bad
  trash
}

model Court {
  id        Int       @id @default(autoincrement())
  name      String
  address   String
  environment String
  capacity  Int
  present   Int
  condition Condition @default(mid)
  news      News[]
  users     User[]
}

model News {
  id Int @id @default(autoincrement())
  courtId Int
  news String
  createdAt DateTime @default(now())
  court Court @relation(fields: [courtId], references: [id])
}



enum Skill {
  goated
  pro
  mid
  beginner
  trash
}
